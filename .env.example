# ============================================================
#  Docker Compose 环境变量模板
#  用法: cp .env.example .env  然后修改 .env 中的值
#  docker-compose.yml 会自动读取同目录下的 .env 文件
# ============================================================

# ----------------------------------------------------------
#  Neo4j 图数据库 — 容器初始化时创建默认用户
# ----------------------------------------------------------
#  用户名（首次启动时创建）
NEO4J_USER=neo4j
#  密码（请修改为强密码，至少 16 位，含大小写+数字+符号）
NEO4J_PASS=changeme_please_replace_this
#  HTTP 端口（浏览器可视化访问）
NEO4J_HTTP_PORT=7474
#  Bolt 端口（应用连接使用）
NEO4J_BOLT_PORT=7687

# ----------------------------------------------------------
#  Redis — 队列与缓存
# ----------------------------------------------------------
#  密码（请修改为强密码）
REDIS_PASSWORD=changeme_please_replace_this
#  端口
REDIS_PORT=6379
