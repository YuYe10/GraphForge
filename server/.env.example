# ============================================
# GraphForge 环境配置模板
# 复制此文件为 .env 并修改配置
#   cp .env.example .env
# ============================================

# Neo4j 图数据库
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASS=neo4j1234

# ============================================
# Redis 配置
# ============================================
# 连接 URL（格式: redis://[:password@]host:port/db）
REDIS_URL=redis://localhost:6379/0

# 密码（Docker Compose 部署时设置，与 REDIS_PASSWORD 环境变量一致）
# REDIS_PASSWORD=your-strong-password-here

# 数据库编号 (0-15)，用于数据隔离，默认 0
REDIS_DB=0

# 连接池（生产环境建议 50-100，开发环境 10-20）
REDIS_MAX_CONNECTIONS=20

# 超时设置（秒）
REDIS_SOCKET_TIMEOUT=5
REDIS_SOCKET_CONNECT_TIMEOUT=3

# 超时自动重试
REDIS_RETRY_ON_TIMEOUT=true

# 连接健康检查间隔（秒）
REDIS_HEALTH_CHECK_INTERVAL=30

# Key 默认过期时间（秒），24小时 = 86400
REDIS_DEFAULT_TTL=86400

# Key 前缀命名空间，用于区分不同环境
REDIS_KEY_PREFIX=graphforge

# ============================================
# AI 配置
# 可选值: openai | anthropic | google | deepseek | qwen | glm |
#         moonshot | ernie | minimax | doubao | ollama | mock
# ============================================
AI_PROVIDER=mock
AI_API_KEY=your-api-key-here
AI_MODEL=qwen-plus
AI_BASE_URL=

# Embedding 模型
EMBEDDING_MODEL=text-embedding-v3

# ============================================
# GraphRAG 配置
# ============================================
ENABLE_NEO4J_GRAPHRAG=true
ENABLE_VECTOR_SEARCH=true

# ============================================
# 文件上传
# ============================================
UPLOAD_DIR=./uploads

# ============================================
# API 服务
# ============================================
API_HOST=0.0.0.0
API_PORT=8000
