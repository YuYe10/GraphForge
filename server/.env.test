# ============================================
# GraphForge 测试环境配置
# 测试数据库使用独立 DB 编号，避免污染开发/生产数据
# ============================================

# Neo4j 测试数据库
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASS=test1234

# ============================================
# Redis 测试配置（使用 DB 1，隔离测试数据）
# ============================================
REDIS_URL=redis://localhost:6379/1
REDIS_DB=1
REDIS_MAX_CONNECTIONS=5
REDIS_KEY_PREFIX=graphforge_test
REDIS_DEFAULT_TTL=3600

# AI 配置（测试模式）
AI_PROVIDER=mock
AI_API_KEY=api-key
AI_MODEL=qwen-plus
AI_BASE_URL=

# Embedding 模型
EMBEDDING_MODEL=text-embedding-v3

# GraphRAG 配置
ENABLE_NEO4J_GRAPHRAG=true
ENABLE_VECTOR_SEARCH=true

# 文件上传
UPLOAD_DIR=./test_uploads

# API
API_HOST=0.0.0.0
API_PORT=8000
