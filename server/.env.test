# Neo4j 测试数据库
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASS=test1234

# AI 配置（测试模式）
AI_PROVIDER=mock  # 或使用真实的 API key
AI_API_KEY=api-key
AI_MODEL=qwen-plus
EMBEDDING_MODEL=text-embedding-v3

# Redis配置
REDIS_URL=redis://localhost:6379/0

# GraphRAG 配置
ENABLE_NEO4J_GRAPHRAG=true
ENABLE_VECTOR_SEARCH=true