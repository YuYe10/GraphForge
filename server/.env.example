# ============================================================
#  GraphForge 后端环境配置模板
#  用法: cp .env.example .env  然后修改 .env 中的值
#
#  注意：Neo4j 用户名密码需与项目根目录 .env 中的值保持一致
#        （docker-compose 用根 .env 创建数据库用户，
#          server/.env 用同样的凭证连接数据库）
# ============================================================

# ----------------------------------------------------------
#  Neo4j 图数据库（与 docker-compose .env 保持一致）
# ----------------------------------------------------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASS=changeme_please_replace_this

# ----------------------------------------------------------
#  Redis 配置
# ----------------------------------------------------------
#  连接 URL（格式: redis://[:password@]host:port/db）
REDIS_URL=redis://localhost:6379/0

#  密码（与 docker-compose 中 REDIS_PASSWORD 保持一致）
REDIS_PASSWORD=changeme_please_replace_this

#  数据库编号 (0-15)，不同项目/环境用不同 DB 号做数据隔离
REDIS_DB=0

#  连接池 — 开发环境 10-20，生产环境 50-100
REDIS_MAX_CONNECTIONS=20

#  超时设置（秒）
REDIS_SOCKET_TIMEOUT=5
REDIS_SOCKET_CONNECT_TIMEOUT=3

#  超时自动重试
REDIS_RETRY_ON_TIMEOUT=true

#  连接健康检查间隔（秒），0 表示禁用
REDIS_HEALTH_CHECK_INTERVAL=30

#  Key 默认过期时间（秒），86400 = 24 小时
REDIS_DEFAULT_TTL=86400

#  Key 前缀命名空间，避免多环境 key 冲突
REDIS_KEY_PREFIX=graphforge

# ----------------------------------------------------------
#  AI 配置
# ----------------------------------------------------------
#  提供商: openai | anthropic | google | deepseek | qwen |
#           glm | moonshot | ernie | minimax | doubao |
#           ollama | mock
AI_PROVIDER=mock
AI_API_KEY=your-api-key-here
AI_MODEL=qwen-plus
AI_BASE_URL=

#  Embedding 模型
EMBEDDING_MODEL=text-embedding-v3

# ----------------------------------------------------------
#  GraphRAG 配置
# ----------------------------------------------------------
ENABLE_NEO4J_GRAPHRAG=true
ENABLE_VECTOR_SEARCH=true

# ----------------------------------------------------------
#  文件上传
# ----------------------------------------------------------
UPLOAD_DIR=./uploads

# ----------------------------------------------------------
#  API 服务
# ----------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
